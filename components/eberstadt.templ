				</p>
				<p class="text-sm text-muted">Im Wiesgarten 11, 35423 Lich-Eberstadt</p>
				<a href="tel:01713223666">+49 (0)1713223666</a>
				<a href="mailto:info@lt-folienwerkstatt.de">info@lt-folienwerkstatt.de</a>
			}
			@sponsorCard("Tobias Häberle", "Gartenservice") {
				<p class="text-sm text-muted">
					Baggerarbeiten | Pflasterarbeiten | Zaunbau | Betonarbeiten | uvm.
				</p>
				<p class="text-sm text-muted">Goethestraße 9, 61200 Wölfersheim</p>
				<a href="tel:015231840291">+49 (0)1778733027</a>
				<a href="mailto:tobias-hoeberle@web.de">tobias-hoeberle@web.de</a>
			}
			@sponsorCard("Christian Peh", "Allround Handwerker") {
				<p class="text-sm text-muted">Bleichstraße 14, 35423 Lich</p>
				<a href="tel:01743256167">+49 (0)1743256167</a>
				<a href="mailto:christianpeh@outlook.de">christianpeh@outlook.de</a>
			}
			@sponsorCard("Natascha Peh", "Beauty & Wellness Lounge") {
				<p class="text-sm text-muted">Bleichstraße 28, 35423 Lich</p>
				<a href="tel:01726558512">+49 (0)1726558512</a>
			}
			@sponsorCard("Björn Höß", "Kraft Transporte GmbH") {
				<p class="text-sm text-muted">Industriestraße 20, 61200 Wölfersheim</p>
				<a href="tel:060363846">+49 (0)60363846</a>
			}
			@sponsorCard("Cathrin Lauria", "Fußpflege Praxis") {
				<p class="text-sm text-muted">Bleichstraße 28, 35423 Lich</p>
				<a href="tel:06004739975">+49 (0)6004739975</a>
			}
			@sponsorCard("Domenico Lauria", "EBL Energiebörse") {
				<p class="text-sm text-muted">Im Wiesgarten 11, 35423 Lich</p>
				<a href="tel:015253866927">+49 (0)15253866927</a>
			}
			@sponsorCard("Andrea Pander", "Raumgestaltung Innen & Außen") {
				<p class="text-sm text-muted">Strackgasse 7, 61440 Oberursel</p>
				<a href="tel:015233818884">+49 (0)15233818884</a>
				<a href="mailto:info@raumtracht-ap.de">info@raumtracht-ap.de</a>
