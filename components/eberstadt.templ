			}
		</div>
		<p class="text-muted text-sm mt-4">14 sponsors loaded. <span class="cursor-blink"></span></p>
	</div>
}

templ Eberstadt() {
	@layoutEberstadt("Eberstadt Kirmes") {
		@sponsors()
		<div class="mt-8">
			@navTemplate([]struct{ Name, URL string }{
				{"Home", "/"},
				{"Eberstadt Kirmes", "/eberstadt/event"},
			})
		</div>
	}
}